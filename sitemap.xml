---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% if page.title and page.url != '/404.html' %}
    <url>
      <loc>{{ site.url }}{{ site.baseurl }}{{ page.url | replace: 'index.html', '' }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
      <changefreq>{% if page.url == '/' %}daily{% else %}weekly{% endif %}</changefreq>
      <priority>{% if page.url == '/' %}1.0{% elsif page.layout == 'recipe' %}0.9{% else %}0.8{% endif %}</priority>
    </url>
    {% endif %}
  {% endfor %}
</urlset>
